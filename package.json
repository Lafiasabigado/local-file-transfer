{
  "name": "local-file-transfer",
  "version": "1.5.3",
  "description": "Secure local file transfer app",
  "author": "Lafia Sabi Gado",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "electron-builder",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dmg",
    "build:linux": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.4",
    "uuid": "^9.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.localshare.app",
    "productName": "LocalShare",
    "directories": {
      "output": "dist"
    },
    "afterPack": "./afterPack.js",
    "files": [
      "main.js",
      "server.js",
      "afterPack.js",
      "public/**/*",
      "package.json",
      "node_modules/express/**/*",
      "node_modules/multer/**/*",
      "node_modules/socket.io/**/*",
      "node_modules/nanoid/**/*",
      "node_modules/uuid/**/*",
      "node_modules/bonjour-service/**/*",
      "node_modules/fast-deep-equal/**/*",
      "node_modules/multicast-dns/**/*",
      "node_modules/dns-packet/**/*",
      "node_modules/dns-equal/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
